# Copy to .env (git-ignored) and fill in.
# Production secrets are injected via `fly secrets` (PRD §13, S2) —
# .env is for local dev only.

# Local Postgres started by `task dev` (compose.yml). Dummy creds — never reuse.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/hello_cards?sslmode=disable

# HTTP listen port for the Go API (main.go).
PORT=8080

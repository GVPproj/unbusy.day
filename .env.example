# Copy to .env (git-ignored) and fill in.
# Production secrets are injected via `fly secrets` (PRD §13, S2) —
# .env is for local dev only.

# Local SQLite database file (git-ignored under tmp/). The app creates and
# migrates it on boot — no container, no external DB. Pragmas: WAL journal,
# 5s busy timeout, foreign keys on, and immediate-transaction write locking
# (BEGIN IMMEDIATE) so writes serialize cleanly under busy_timeout.
DATABASE_URL=file:./tmp/unbusy.db?_pragma=foreign_keys(1)&_pragma=busy_timeout(5000)&_pragma=journal_mode(WAL)&_txlock=immediate

# HTTP listen port for the Go API (main.go).
PORT=8080

# Email (auth OTP). Leave SMTP_HOST unset for local dev — the app falls back
# to LogMailer and prints login codes to stdout. Set these (via `fly secrets`
# in prod, never committed) to send real mail through AWS SES SMTP.
# SMTP_HOST=email-smtp.us-west-2.amazonaws.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=test@example.com

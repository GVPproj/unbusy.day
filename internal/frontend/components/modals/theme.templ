package modals

// Picker ingredients (scheme swatch gradients, feeling fonts and preview
// glyphs); shared with the guide's "Power User?" pane so its miniatures
// can't drift from the picker.
const (
	swatchSolarizedLight = "linear-gradient(135deg, hsl(44, 86%, 94%) 50%, hsl(46, 42%, 88%) 50%)"
	swatchSolarizedOsaka = "linear-gradient(135deg, hsl(192, 100%, 5%) 50%, hsl(192, 100%, 10%) 50%)"
	swatchCatppuccin     = "linear-gradient(135deg, hsl(240, 21%, 15%) 50%, hsl(237, 16%, 23%) 50%)"

	feelingCozyFont  = "Zen Maru Gothic, system-ui, sans-serif"
	feelingPixelFont = "Gohu, ui-monospace, monospace"

	glyphCozy  = `<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2S2 6.477 2 12s4.477 10 10 10" opacity=".5"/><path fill="currentColor" fill-rule="evenodd" d="M12 7.25a.75.75 0 0 1 .75.75v3.69l2.28 2.28a.75.75 0 1 1-1.06 1.06l-2.5-2.5a.75.75 0 0 1-.22-.53V8a.75.75 0 0 1 .75-.75" clip-rule="evenodd"/></svg>`
	glyphPixel = `<svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M6 2h12v2H6zM2 6h2v12H2zm18 0h2v12h-2zm-2-2h2v2h-2zM4 4h2v2H4zm2 18h12v-2H6zm12-2h2v-2h-2zM4 20h2v-2H4zm7-14h2v7h-2zm2 7h2v2h-2zm2 2h2v2h-2z"/></svg>`

	// PROTOTYPE(business-feeling): candidate rows for a third "Business"
	// feeling — font settled on JetBrains Mono, rows compare icon packs
	// (clock glyph from each). Keep the winner, strip the rest.
	// grep: business-
	feelingBizFont = "JetBrains Mono, ui-monospace, monospace"

	glyphBizA = `<svg viewBox="0 0 24 24" aria-hidden="true"><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></g></svg>`
	glyphBizB = `<svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>`
	glyphBizC = `<svg viewBox="0 0 24 24" stroke-width="1.5" fill="none" aria-hidden="true"><path d="M12 6L12 12L18 12" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/></svg>`
	glyphBizD = `<svg viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="0.75" stroke-linejoin="round" aria-hidden="true"><path d="M12.5 7.25a.75.75 0 0 0-1.5 0v5.5c0 .27.144.518.378.651l3.5 2a.75.75 0 0 0 .744-1.302L12.5 12.315V7.25Z"/><path d="M12 1c6.075 0 11 4.925 11 11s-4.925 11-11 11S1 18.075 1 12 5.925 1 12 1ZM2.5 12a9.5 9.5 0 0 0 9.5 9.5 9.5 9.5 0 0 0 9.5-9.5A9.5 9.5 0 0 0 12 2.5 9.5 9.5 0 0 0 2.5 12Z"/></svg>`
)

// themeOption is one row in the picker; swatch shows the theme's bg/column split.
templ themeOption(id string, label string, swatch string) {
	<button
		class="option-row"
		data-class:active={ "$_colorscheme === '" + id + "'" }
		data-on:click={ "$_colorscheme = '" + id + "'" }
	>
		<span class="swatch" style={ "background: " + swatch }></span>
		{ label }
	</button>
}

// feelingOption is one row in the feeling picker: previews both axes by showing
// the icon set's glyph and the label in the feeling's font. Writes $_feeling;
// pixel adds the pixelated rendering hint for the 8-bit set.
//
// family must be UNQUOTED: templ double-escapes quotes in a dynamic style attr,
// which kills the declaration and falls back to the default font.
templ feelingOption(id string, label string, family string, pixel bool, preview templ.Component) {
	<button
		class="option-row"
		data-class:active={ "$_feeling === '" + id + "'" }
		data-on:click={ "$_feeling = '" + id + "'" }
		style={ "font-family: " + family }
	>
		<span class={ "feeling-preview", templ.KV("pixelated", pixel) }>
			@preview
		</span>
		{ label }
	</button>
}

// ThemeModal's two sections write $_colorscheme and $_feeling, which the layout
// <html> mirrors into data-colorscheme/data-feeling (and localStorage), so both
// swaps are live without closing.
templ ThemeModal() {
	<dialog
		id="theme-modal"
		class="app-dialog"
		closedby="any"
		aria-labelledby="theme-modal-title"
	>
		<h2 id="theme-modal-title">Theme</h2>
		<h3>Feeling</h3>
		@feelingOption("cozy", "Cozy", feelingCozyFont, false, templ.Raw(glyphCozy))
		@feelingOption("pixel", "Pixel", feelingPixelFont, true, templ.Raw(glyphPixel))
		// PROTOTYPE(business-feeling): four icon-pack candidates, pick one.
		@feelingOption("business-a", "Business (Lucide)", feelingBizFont, false, templ.Raw(glyphBizA))
		@feelingOption("business-b", "Business (Heroicons)", feelingBizFont, false, templ.Raw(glyphBizB))
		@feelingOption("business-c", "Business (Iconoir)", feelingBizFont, false, templ.Raw(glyphBizC))
		@feelingOption("business-d", "Business (Octicons)", feelingBizFont, false, templ.Raw(glyphBizD))
		<h3>Colours</h3>
		@themeOption("solarized-light", "Solarized Light", swatchSolarizedLight)
		@themeOption("solarized-osaka", "Solarized Dark Osaka", swatchSolarizedOsaka)
		@themeOption("catppuccin-mocha", "Catppuccin Mocha", swatchCatppuccin)
		<p class="theme-credits">
			Colours from
			<a href="https://ethanschoonover.com/solarized" target="_blank" rel="noopener">Solarized</a>,
			<a href="https://github.com/craftzdog/solarized-osaka.nvim" target="_blank" rel="noopener">Solarized Osaka</a>,
			and <a href="https://catppuccin.com" target="_blank" rel="noopener">Catppuccin</a>.
		</p>
		<footer>
			<button class="btn" commandfor="theme-modal" command="close">Done</button>
		</footer>
	</dialog>
}

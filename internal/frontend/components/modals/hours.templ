package modals

import (
	"fmt"
	"strconv"

	"github.com/GVPproj/unbusy.day/internal/block"
)

// signalsObject seeds the modal's four signals as a Datastar object literal.
// Needed because the keyed form (data-signals:firstOccupiedSlot) gets lowercased
// by the browser; the object literal preserves the camelCase keys verbatim.
func signalsObject(b block.Bounds, env block.Envelope) string {
	return fmt.Sprintf("{start: %d, end: %d, firstOccupiedSlot: %d, lastOccupiedEnd: %d}",
		b.Start, b.End, env.FirstSlot, env.LastEnd)
}

// startOptions renders the start select's half-hour options (current pre-selected).
// Each disables past the first occupied slot — raising start there would strand
// the earliest block.
templ startOptions(from, to, current int) {
	for s := from; s <= to; s++ {
		<option value={ strconv.Itoa(s) } selected?={ s == current } data-attr:disabled={ strconv.Itoa(s) + " > $firstOccupiedSlot" }>{ clockLabel(s) }</option>
	}
}

// endOptions renders the end select's half-hour options (current pre-selected).
// Each disables below the last occupied end — dropping end there would strand
// the latest block.
templ endOptions(from, to, current int) {
	for s := from; s <= to; s++ {
		<option value={ strconv.Itoa(s) } selected?={ s == current } data-attr:disabled={ strconv.Itoa(s) + " < $lastOccupiedEnd" }>{ clockLabel(s) }</option>
	}
}

// clockLabel renders a slot index (30-min steps from 00:00) as a clock time
// ("9:00", "9:30").
func clockLabel(s int) string {
	if s%2 == 1 {
		return strconv.Itoa(s/2) + ":30"
	}
	return strconv.Itoa(s/2) + ":00"
}

// HoursModal is the day-bounds editor. Selects cover the hard 4:00–18:00
// limits; options outside the occupied envelope disable reactively so a
// shrink-into-occupied window is never offered. Server still enforces the
// limits as a concurrent-edit safety net.
templ HoursModal(b block.Bounds, env block.Envelope) {
	<dialog
		id="bounds-modal"
		class="app-dialog"
		closedby="any"
		data-signals={ signalsObject(b, env) }
		aria-labelledby="bounds-modal-title"
	>
		<h2 id="bounds-modal-title">Working Hours</h2>
		<p data-show="$firstOccupiedSlot < $lastOccupiedEnd">Your blocks will stay put</p>
		<label>
			Start
			<select class="field" data-on:change="$start = +evt.target.value">
				@startOptions(block.MinDayStart, block.MaxDayEnd-1, b.Start)
			</select>
		</label>
		<label>
			End
			<select class="field" data-on:change="$end = +evt.target.value">
				@endOptions(block.MinDayStart+1, block.MaxDayEnd, b.End)
			</select>
		</label>
		<footer>
			<button
				class="btn btn-secondary"
				autofocus
				commandfor="bounds-modal"
				command="close"
			>Cancel</button>
			<button
				class="btn"
				commandfor="bounds-modal"
				command="close"
				data-on:click="@post('/blocks/bounds')"
			>Save</button>
		</footer>
	</dialog>
}

package components

// Styling lives in app.css: @scope (.sidenav) owns the rail↔drawer geometry,
// .menu-toggle/.nav-scrim the mobile chrome. `.open` (data-class:open) is the
// drawer/X-morph hook.

// MenuToggle is the mobile hamburger, rendered at .shell level so it escapes
// the header's stacking context and floats above the open drawer.
templ MenuToggle() {
	<button
		class="menu-toggle"
		data-on:click="$_navopen = !$_navopen"
		data-attr:aria-expanded="$_navopen ? 'true' : 'false'"
		data-class:open="$_navopen"
		aria-controls="sidenav"
		aria-label="Toggle menu"
	>
		<span>
			@IconMenu()
		</span>
	</button>
}

templ SideNav() {
	<div class="nav-scrim" data-class:open="$_navopen" data-on:click="$_navopen = false"></div>
	<nav id="sidenav" class="sidenav" data-class:open="$_navopen">
		<div title="unbusy.day" class="nav-logo">
			@UBLogo("51", "22")
		</div>
		<button commandfor="bounds-modal" command="show-modal" data-on:click="$_navopen = false">
			<span class="nav-icon">
				@IconHours()
			</span><span>Set Hours</span>
		</button>
		// Disabled on an empty day: the envelope collapses to first >= last.
		<button data-attr:disabled="$firstOccupiedSlot >= $lastOccupiedEnd" commandfor="clear-modal" command="show-modal" data-on:click="$_navopen = false">
			<span class="nav-icon">
				@IconClear()
			</span><span>Clear</span>
		</button>
		<button class="nav-tail" commandfor="theme-modal" command="show-modal" data-on:click="$_navopen = false">
			<span class="nav-icon">
				@IconTheme()
			</span><span>Theme</span>
		</button>
		<button commandfor="guide-modal" command="show-modal" data-on:click="$_navopen = false">
			<span class="nav-icon">
				@IconGuide()
			</span><span>Guide</span>
		</button>
		<button data-on:click="@post('/logout')">
			<span class="nav-icon">
				@IconLogout()
			</span><span>Log Out</span>
		</button>
	</nav>
}

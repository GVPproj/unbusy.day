package components

// Icons pair with the font under the "feeling" axis: both sets ship and
// app.css's :root[data-feeling] toggle shows one, so the swap is live with no
// round-trip. All draw with currentColor. 24px maps the pixel grid 1:1 to
// device pixels so 8-bit edges stay crisp.

// IconMenu is the mobile hamburger toggle: cozy "Jelly Wobble" (swaying bars),
// pixel "Tetris Drop" (falling blocks), both folding into an X when open.
// Styling/morph live in app.css (icon.templ section).
templ IconMenu() {
	<span class="menu-cozy">
		<span class="bar"></span>
		<span class="bar"></span>
		<span class="bar"></span>
	</span>
	<span class="menu-pixel">
		<span class="trow"><i></i><i></i><i></i><i></i></span>
		<span class="trow"><i></i><i></i><i></i><i></i></span>
		<span class="trow"><i></i><i></i><i></i><i></i></span>
	</span>
	/* cozy-3 "Sleepy Cat" — spare alternate kept for future A/B testing. Swap in
	   for .menu-cozy above and uncomment the .menu-cat block in app.css.
	<span class="menu-cat">
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<g class="grp">
				<path class="ear" d="M5 8 L4 4 L8 6"></path>
				<path class="ear" d="M19 8 L20 4 L16 6"></path>
				<line x1="3" y1="8" x2="21" y2="8"></line>
				<line x1="3" y1="13" x2="21" y2="13"></line>
				<line x1="6" y1="18" x2="18" y2="18"></line>
				<path class="eye-closed" d="M7.5 10.6 q1.2 1 2.4 0"></path>
				<path class="eye-closed" d="M14.1 10.6 q1.2 1 2.4 0"></path>
				<circle class="eye-open" cx="8.7" cy="10.6" r="1.1" fill="currentColor" stroke="none"></circle>
				<circle class="eye-open" cx="15.3" cy="10.6" r="1.1" fill="currentColor" stroke="none"></circle>
			</g>
			<g class="xg"><line x1="6" y1="6" x2="18" y2="18"></line><line x1="18" y1="6" x2="6" y2="18"></line></g>
		</svg>
	</span>
	*/
}

templ IconHours() {
	@templ.Raw(`<svg class="icon icon-solar" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2S2 6.477 2 12s4.477 10 10 10" opacity=".5"/><path fill="currentColor" fill-rule="evenodd" d="M12 7.25a.75.75 0 0 1 .75.75v3.69l2.28 2.28a.75.75 0 1 1-1.06 1.06l-2.5-2.5a.75.75 0 0 1-.22-.53V8a.75.75 0 0 1 .75-.75" clip-rule="evenodd"/></svg>`)
	@templ.Raw(`<svg class="icon icon-pixel" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M6 2h12v2H6zM2 6h2v12H2zm18 0h2v12h-2zm-2-2h2v2h-2zM4 4h2v2H4zm2 18h12v-2H6zm12-2h2v-2h-2zM4 20h2v-2H4zm7-14h2v7h-2zm2 7h2v2h-2zm2 2h2v2h-2z"/></svg>`)
}

templ IconTheme() {
	@templ.Raw(`<svg class="icon icon-solar" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" fill-rule="evenodd" d="M22 12c0 5.523-4.477 10-10 10a10 10 0 0 1-3.321-.564A9 9 0 0 1 8 18a8.97 8.97 0 0 1 2.138-5.824A6.5 6.5 0 0 0 15.5 15a6.5 6.5 0 0 0 5.567-3.143c.24-.396.933-.32.933.143" clip-rule="evenodd" opacity=".5"/><path fill="currentColor" d="M2 12c0 4.359 2.789 8.066 6.679 9.435A9 9 0 0 1 8 18c0-2.221.805-4.254 2.138-5.824A6.47 6.47 0 0 1 9 8.5a6.5 6.5 0 0 1 3.143-5.567C12.54 2.693 12.463 2 12 2C6.477 2 2 6.477 2 12"/></svg>`)
	@templ.Raw(`<svg class="icon icon-pixel" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M18 22H8v-2h10zM8 20H6v-2h2zm12 0h-2v-2h2zM6 18H4v-2h2zm16 0h-2v-4h-2v-2h2v-2h2zM4 16H2V6h2zm14 0h-6v-2h6zm-6-2h-2v-2h2zm-2-2H8V6h2zM6 6H4V4h2zm8-2h-2v2h-2V4H6V2h8z"/></svg>`)
}

